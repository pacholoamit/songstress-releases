# Generated by `songstress install` — VPN egress overlay. The songstress
# service joins gluetun's network namespace (wired in compose.yaml), so all
# acquisition egress rides the tunnel; Navidrome stays outside and publishes
# its own port, so browser streaming is unaffected by tunnel hiccups.
services:
  gluetun:
    image: {{ .Pins.gluetun }}
    container_name: songstress-gluetun
    cap_add:
      - NET_ADMIN
    devices:
      - /dev/net/tun:/dev/net/tun
    ports:
      # Published here because songstress shares this network namespace.
      - "${SONGSTRESS_PORT}:8090"
    volumes:
      - ./gluetun:/gluetun
    environment:
      - VPN_SERVICE_PROVIDER=${VPN_SERVICE_PROVIDER}
      - VPN_TYPE=wireguard
      - WIREGUARD_PRIVATE_KEY=${WIREGUARD_PRIVATE_KEY}
      - WIREGUARD_ADDRESSES=${WIREGUARD_ADDRESSES}
      # Keep the UI reachable and let LAN/Docker traffic bypass the tunnel.
      - FIREWALL_INPUT_PORTS=8090
      - FIREWALL_OUTBOUND_SUBNETS=${LAN_SUBNET}
      # Keep Docker DNS so `navidrome`/`audiomuse` resolve from this netns.
      - DNS_KEEP_NAMESERVER=on
      - TZ=${TZ}
    restart: unless-stopped
