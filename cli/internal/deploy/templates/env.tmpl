# Generated by `songstress install` — secrets live HERE and only here
# (mode 0600). songstress.lock.json carries no secrets.

# ── basics ───────────────────────────────────────────────────────────────────
TZ={{ .TZ }}
PUID={{ .PUID }}
PGID={{ .PGID }}
MUSIC_DIR={{ .MusicDir }}
SONGSTRESS_PORT={{ .Port }}
ENABLE_TELEMETRY={{ if .Telemetry }}true{{ else }}false{{ end }}

# ── dashboard admin ──────────────────────────────────────────────────────────
SONGSTRESS_ADMIN_EMAIL={{ if .AdminEmail }}{{ .AdminEmail }}{{ else }}admin@songstress.local{{ end }}
SONGSTRESS_ADMIN_PASSWORD={{ .S.AdminPassword }}

# ── Navidrome (managed sibling service) ──────────────────────────────────────
NAVIDROME_PORT=4533
NAVIDROME_PASSWORD={{ .S.NavidromePassword }}
{{- if .Discovery }}

# ── Discovery (AudioMuse-AI side-car) ────────────────────────────────────────
AUDIOMUSE_API_TOKEN={{ .S.AudioMuseToken }}
AUDIOMUSE_PASSWORD={{ .S.AudioMusePassword }}
AUDIOMUSE_DB_PASSWORD={{ .S.AudioMuseDB }}
{{- end }}
{{- if .VPN }}

# ── VPN egress (gluetun) ─────────────────────────────────────────────────────
VPN_SERVICE_PROVIDER=protonvpn
WIREGUARD_PRIVATE_KEY={{ .S.WGPrivateKey }}
WIREGUARD_ADDRESSES=10.2.0.2/32
LAN_SUBNET=172.16.0.0/12
{{- end }}
{{- if .Tailscale }}

# ── Tailscale ────────────────────────────────────────────────────────────────
TS_AUTHKEY={{ .S.TSAuthKey }}
{{- end }}
