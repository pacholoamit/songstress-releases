# Generated by `songstress install` — Domain & HTTPS overlay (Caddy with
# automatic Let's Encrypt). Caddy fronts the dashboard; the direct port
# publish is dropped from the songstress service.
services:
  caddy:
    image: {{ .Pins.caddy }}
    container_name: songstress-caddy
    ports:
      - "80:80"
      - "443:443"
    volumes:
      - ./Caddyfile:/etc/caddy/Caddyfile:ro
      - caddy-data:/data
      - caddy-config:/config
    restart: unless-stopped

volumes:
  caddy-data:
  caddy-config:
